# Bloom Spa — environment template. Copy to .env.local and fill in values.

# Site
NEXT_PUBLIC_SITE_URL=https://bloomspa.rw

# Business
NEXT_PUBLIC_BUSINESS_NAME=Bloom Spa
NEXT_PUBLIC_BUSINESS_ADDRESS=ST KG 326, Gate 80, Kibagabaga, Kigali, Rwanda
NEXT_PUBLIC_BUSINESS_LAT=-1.9325
NEXT_PUBLIC_BUSINESS_LNG=30.1158
NEXT_PUBLIC_BUSINESS_PHONE=+250788000000
NEXT_PUBLIC_BUSINESS_EMAIL=hello@bloomspa.rw
NEXT_PUBLIC_BUSINESS_WHATSAPP=250788000000
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/bloomspa924/

# Hours
NEXT_PUBLIC_HOURS_WEEKDAY=09:00-20:00
NEXT_PUBLIC_HOURS_SATURDAY=09:00-20:00
NEXT_PUBLIC_HOURS_SUNDAY=10:00-18:00

# Currency
NEXT_PUBLIC_CURRENCY=RWF

# Notification channels
NEXT_PUBLIC_NOTIFY_EMAIL_ENABLED=true
NEXT_PUBLIC_NOTIFY_WHATSAPP_ENABLED=true

# EmailJS (https://www.emailjs.com)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
